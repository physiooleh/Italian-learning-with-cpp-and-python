#include <iostream>
#include <string>
using namespace std;

int main() {

    string czas;

    cout << "Wpisz nazwe czasu (Indikativ Prasens): ";
    getline(cin, czas);

    if (czas == "Indikativ Prasens") {

        cout << "\nCzas terazniejszy w trybie oznajmujacym\n";
        cout << "Uzywany do opisywania czynnosci dziejacych sie teraz.\n";
        cout << "Uzywany do opisywania faktow ogolnych.\n";
        cout << "Moze byc uzywany zamiast czasu przyszlego.\n\n";

        cout << "Formy czasownika 'sein' w Indikativ Prasens:\n";
        cout << "ich bin\n";
        cout << "du bist\n";
        cout << "er/sie/es ist\n";
        cout << "wir sind\n";
        cout << "ihr seid\n";
        cout << "sie sind\n\n";

        string zdanie;
        cout << "Wpisz zdanie po niemiecku: ";
        getline(cin, zdanie);

        if (zdanie.find("bin") != string::npos ||
            zdanie.find("bist") != string::npos ||
            zdanie.find("ist") != string::npos ||
            zdanie.find("sind") != string::npos ||
            zdanie.find("seid") != string::npos) {

            cout << "Wyglada na poprawna forme czasu terazniejszego.\n";
        }
        else {
            cout << "Nie znaleziono formy 'sein' w czasie terazniejszym.\n";
        }

    }
    else {
        cout << "Nie rozpoznano czasu.\n";
    }

    return 0;
}
