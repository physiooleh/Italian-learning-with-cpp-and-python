cout << "Du bist zwischen Frankreich und Italien hin- und hergerissen gewenen weil das Essen \n";

map<string, string> dictionary = {
{"immer", "zawsze"},
{"uberzeugt", "uberzeugen - przekonywac"},
{"hergerissen", "majacy sprzeczne uczucia"}
};

string input;
while (true) {
